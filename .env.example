APP_NAME="Victoria Love Credit"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://victorialovecredit.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: set MAIL_MAILER to your real provider (smtp / resend / ses / mailgun) before launch.
# MAIL_MAILER=log dumps form notifications to storage/logs/* instead of sending.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@victorialovecredit.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Credit Repair Cloud API
CRC_API_KEY=
CRC_SECRET_KEY=
CRC_BASE_URL=https://app.creditrepaircloud.com
CRC_ASSIGNED_TO=
CRC_AGREEMENT="Default Agreement"
CALENDLY_URL=

# Authorize.Net (PRODUCTION — fill with live merchant credentials, never commit real values)
AUTHORIZE_NET_ENV=production
AUTHORIZE_NET_API_LOGIN_ID=
AUTHORIZE_NET_TRANSACTION_KEY=
AUTHORIZE_NET_PUBLIC_CLIENT_KEY=
AUTHORIZE_NET_SIGNATURE_KEY=
AUTHORIZE_NET_WEBHOOK_ENFORCE_SIGNATURE=true

# Google Sheets — Apps Script web-app webhook
GOOGLE_SHEETS_WEBHOOK_URL=

# GoHighLevel — one inbound webhook per lead form (Automation → Workflows → Inbound Webhook trigger)
GHL_WEBHOOK_LEAD=
GHL_WEBHOOK_CONTACT=
GHL_WEBHOOK_FUNDING=
GHL_WEBHOOK_MENTORSHIP=
GHL_WEBHOOK_STRATEGY=
GHL_WEBHOOK_ONBOARDING=
# Optional shared fallback (used only if a form above has no URL set)
GHL_WEBHOOK_URL=

REVIEWER_EMAIL=
REVIEWER_PASSWORD=
